# ─────────────────────────────────────────────
# SubTerra — Environment Variables
# Copy this file to .env and fill in values
# cp .env.example .env
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_NAME=SubTerra
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-in-production
API_VERSION=v1

# ── Database (TimescaleDB) ───────────────────
DATABASE_URL=postgresql://subterra_user:subterra_pass@localhost:5432/subterra
POSTGRES_DB=subterra
POSTGRES_USER=subterra_user
POSTGRES_PASSWORD=subterra_pass

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379
CACHE_EXPIRE_SECONDS=3600
CACHE_TTL_SEC=300

# ── Data Sources ─────────────────────────────
INDIA_WRIS_BASE_URL=https://indiawris.gov.in
WRIS_BASE_URL=https://indiawris.gov.in/wris
IMD_BASE_URL=https://imdaws.imd.gov.in
DATA_GOV_API_KEY=

# ── Scraper ───────────────────────────────────
FETCH_INTERVAL_SEC=900
DATA_REFRESH_INTERVAL=21600
MAX_RETRIES=3
RETRY_BACKOFF_SEC=10
REQUEST_TIMEOUT_SEC=30

# ── Algorithm Defaults ────────────────────────
TASK1_DEFAULT_HOURS=168
TASK2_DEFAULT_DAYS=365
TASK3_DEFAULT_DAYS=365
ALERT_LOOKBACK_HOURS=48
